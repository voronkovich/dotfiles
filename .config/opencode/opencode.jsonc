/*
* Free Tier:
*
* https://www.askcodi.com/models
* https://aihubmix.com/models
* https://kilo.ai/docs/code-with-ai/agents/free-and-budget-models#kilo-gateway-free-models
* https://opencode.ai/docs/zen/#pricing
*/
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "kilo/kilo-auto/free",
  "small_model": "kilo/kilo-auto/free",
  "enabled_providers": [
    "aihubmix",
    "askcodi",
    "kilo",
    "opencode",
  ],
  "provider": {
    "aihubmix": {
      "whitelist": [
        "coding-glm-5-free",
        "coding-glm-5.1-free",
        "coding-minimax-m2.7-free",
        "gpt-4.1-free",
        "gpt-4o-free",
        "kimi-for-coding-free",
      ]
    },
    "kilo": {
      "whitelist": [
        "kilo-auto/free"
      ]
    },
    "askcodi": {
      "name": "AskCodi",
      "options": {
        "baseURL": "https://api.askcodi.com/v1",
        "apiKey": "{env:ASKCODI_API_KEY}",
      },
      "models": {
        "deepseek/deepseek-v3.2:free": {
          "name": "DeepSeek-V3.2",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 64000,
          },
          "cost": {
            "input": 0,
            "output": 0,
          }
        },
        "google/gemini-3-flash:free": {
          "name": "Google Gemini 3 Flash",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 65000,
          },
          "cost": {
            "input": 0,
            "output": 0,
          }
        },
        "openai/gpt-5-mini:free": {
          "name": "GPT-5 mini",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 400000,
          },
          "cost": {
            "input": 0,
            "output": 0,
          }
        },
        "xai/grok-code-fast-1:free": {
          "name": "Grok Code Fast 1",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 256000,
            "output": 10000,
          },
          "cost": {
            "input": 0,
            "output": 0,
          }
        },
        "zai/glm-4.7:free": {
          "name": "GLM-4.7",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 200000,
          },
          "cost": {
            "input": 0,
            "output": 0,
          }
        },
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  }
}
