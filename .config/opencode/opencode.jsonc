/*
* Free Tier:
*
* https://www.askcodi.com/models
* https://aihubmix.com/models
* https://kilo.ai/docs/code-with-ai/agents/free-and-budget-models#kilo-gateway-free-models
* https://opencode.ai/docs/zen/#pricing
*/
{
  "$schema": "https://opencode.ai/config.json",
  "model": "kilo/kilo-auto/free",
  "small_model": "kilo/kilo-auto/free",
  "enabled_providers": [
    "aihubmix",
    "askcodi",
    "kilo",
    "opencode",
  ],
  "autoupdate": false,
  "provider": {
    "aihubmix": {},
    "askcodi": {
      "name": "AskCodi",
      "options": {
        "baseURL": "https://api.askcodi.com/v1",
        "apiKey": "{env:ASKCODI_API_KEY}",
      },
      "models": {
        "xai/grok-code-fast-1:free": {
          "name": "Grok Code Fast 1",
          "attachment": false,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 256000,
            "output": 10000,
          },
          "cost": {
            "input": 0,
            "output": 0,
          }
        }
      }
    }
  }
}
