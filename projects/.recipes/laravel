#!/usr/bin/env zsh

remove_sail() {
    # https://laravel.com/docs/sail
    rm bootstrap/cache/*.php && composer remove --dev laravel/sail
}

install_pest() {
    # https://pestphp.com/docs/installation
    composer remove --dev phpunit/phpunit &&
        composer require pestphp/pest pestphp/pest-plugin-laravel --dev --with-all-dependencies &&
        yes 'no' | php vendor/bin/pest --init &&
        find tests -iname ExampleTest.php -delete
}

install_boost() {
    # https://laravel.com/docs/boost#installation
    composer require --dev laravel/boost &&
        php artisan boost:install -n
}

setup_php_version() {
    php -v | read php version etc

    echo "${version%.*}" > .php-version
}

setup_symfony_cli() {
	echo -n "# https://symfony.com/doc/current/setup/symfony_cli.html#advanced-configuration

# proxy:
#   domains:
#     - '${PWD##*/}'

workers:
  # Auto start Docker compose when starting server
  # docker_compose: ~
  #
  # mailpit:
  #    cmd: ['mailpit']

  artisan:queue:
    cmd: ['php', 'artisan',  'queue:listen', '--tries=1']

  vite:
    cmd: ['npm', 'run', 'dev']" > .symfony.local.yaml
}

setup_aider() {
    echo -n 'lint-cmd: "php vendor/bin/pint --test"
test-cmd: "php artisan test"' > .aider.conf.yml
}

symfony composer create-project laravel/laravel . &&
    rsync --recursive "${PROJECTS}/.templates/laravel/" ./ &&
    remove_sail &&
    npm install &&
    install_pest &&
    install_boost &&
    setup_php_version &&
    setup_symfony_cli &&
    setup_aider &&
    git init && git add . && git commit -m 'Initial commit' >/dev/null
