#!/usr/bin/bash

set -euo pipefail
shopt -s lastpipe nullglob dotglob

declare -r pkg='@google/gemini-cli'

if ! npm list -g "${pkg}" &>/dev/null; then
    npm install -gy "${pkg}"
fi

declare -r proxy="$(proxy-start)"

export HTTP_PROXY="${proxy}"
export HTTPS_PROXY="${proxy}"
export "$(grep GEMINI_API_KEY "${HOME}/.secrets/envs")"

exec npx "${pkg}" "$@"
